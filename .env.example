# Copy this file to .env and fill in your bot token.
# .env is gitignored; .env.example is committed.

# Telegram bot token from @BotFather (/newbot). REQUIRED.
TELEGRAM_BOT_TOKEN=your_token_here

# URL of the running MCP server. Must include the /mcp path.
# Default matches `python -m mcp_server.server` on this host.
MCP_SERVER_URL=http://127.0.0.1:8765/mcp

# Which detector backend to use. Currently only "siglip" is registered.
DETECTOR_MODEL=siglip
